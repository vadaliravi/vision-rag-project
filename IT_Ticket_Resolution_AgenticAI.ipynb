# ==========================================
# 📌 STEP 1: INSTALL (Run in Colab Cell)
# ==========================================
# pip install langgraph langchain langchain-community langchain-groq groq requests gradio

# ==========================================
# 📌 STEP 2: IMPORT LIBRARIES
# ==========================================
import os
import requests
from typing import TypedDict
import gradio as gr

from langgraph.graph import StateGraph, END
from langchain_core.messages import HumanMessage
from langchain_groq import ChatGroq

# ==========================================
# 📌 STEP 3: API KEYS
# ==========================================
os.environ["GROQ_API_KEY"] = "YOUR_GROQ_API_KEY"
os.environ["SERPER_API_KEY"] = "YOUR_SERPER_API_KEY"

# ==========================================
# 📌 STEP 4: LLM SETUP (GROQ LLAMA 3)
# ==========================================
llm = ChatGroq(
    model="llama-3.1-8b-instant",
    temperature=0.2
)

# ==========================================
# 📌 STEP 5: STATE DEFINITION
# ==========================================
class TicketState(TypedDict):
    ticket: str
    priority: str
    classification: str
    search_results: str
    solution: str

# ==========================================
# 📌 STEP 6: CLASSIFICATION NODE
# ==========================================
def classify_ticket(state: TicketState):
    prompt = f"""
Classify IT ticket into:
Network / Software / Hardware / Access / Security / Other

Ticket: {state['ticket']}
"""
    response = llm.invoke([HumanMessage(content=prompt)])
    state["classification"] = response.content.strip()
    return state

# ==========================================
# 📌 STEP 7: WEB SEARCH NODE (SERPER)
# ==========================================
def search_web(state: TicketState):
    query = f"{state['ticket']} fix {state['classification']}"

    url = "https://google.serper.dev/search"
    headers = {
        "X-API-KEY": os.environ["SERPER_API_KEY"],
        "Content-Type": "application/json"
    }
    response = requests.post(url, headers=headers, json={"q": query})
    data = response.json()

    snippets = [item.get("snippet", "") for item in data.get("organic", [])[:3]]
    state["search_results"] = "\n".join(snippets)
    return state

# ==========================================
# 📌 STEP 8: SOLUTION NODE
# ==========================================
def generate_solution(state: TicketState):
    prompt = f"""
You are an expert IT support engineer.

Ticket: {state['ticket']}
Priority: {state['priority']}
Category: {state['classification']}

Web Insights:
{state['search_results']}

Provide:
1. Root Cause
2. Step-by-step Fix
3. Preventive Actions
"""
    response = llm.invoke([HumanMessage(content=prompt)])
    state["solution"] = response.content
    return state

# ==========================================
# 📌 STEP 9: BUILD LANGGRAPH
# ==========================================
builder = StateGraph(TicketState)

builder.add_node("classify", classify_ticket)
builder.add_node("search", search_web)
builder.add_node("solve", generate_solution)

builder.set_entry_point("classify")
builder.add_edge("classify", "search")
builder.add_edge("search", "solve")
builder.add_edge("solve", END)

app = builder.compile()

# ==========================================
# 📌 STEP 10: RUN AGENT
# ==========================================
def run_agent(ticket, priority):
    result = app.invoke({
        "ticket": ticket,
        "priority": priority,
        "classification": "",
        "search_results": "",
        "solution": ""
    })
    return result["classification"], result["solution"]

# ==========================================
# 📌 STEP 11: PROFESSIONAL GRADIO UI
# ==========================================

css = """
body {background: linear-gradient(120deg, #e0f7fa, #f1f8e9);} 
#title {text-align:center; font-size:32px; font-weight:bold; color:#1b5e20;}
#marquee {color:#0d47a1; font-size:18px;}
.gr-button {background-color:#2e7d32 !important; color:white !important;}
"""

with gr.Blocks(css=css) as demo:

    gr.Markdown("""<div id='title'>🧠 IT Ticket Resolution</div>""")

    gr.HTML("""
    <marquee id='marquee'>🚀 IT Ticket Resolution by Dr.Arpit Yadav 🚀</marquee>
    """)

    with gr.Row():
        ticket_input = gr.Textbox(label="Enter IT Ticket Issue", lines=3, placeholder="Describe the issue...")

    with gr.Row():
        priority = gr.Dropdown(
            ["Low", "Medium", "High", "Critical"],
            label="Select Priority"
        )

    with gr.Row():
        category_output = gr.Textbox(label="Predicted Category")
        solution_output = gr.Textbox(label="Resolution Steps", lines=10)

    with gr.Row():
        btn = gr.Button("Resolve Ticket")
        clear = gr.Button("Clear")

    btn.click(run_agent, inputs=[ticket_input, priority], outputs=[category_output, solution_output])

    clear.click(lambda: ("", "", ""), outputs=[ticket_input, category_output, solution_output])

# ==========================================
# 📌 STEP 12: LAUNCH
# ==========================================
if __name__ == "__main__":
    demo.launch()

# ==========================================
# 🧪 TEST CASES
# ==========================================

def test_basic():
    cat, sol = run_agent("VPN not connecting", "High")
    assert isinstance(cat, str)
    assert isinstance(sol, str)


def test_empty():
    cat, sol = run_agent("", "Low")
    assert isinstance(sol, str)

