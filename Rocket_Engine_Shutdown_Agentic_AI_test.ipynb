import os
from typing import TypedDict

from langgraph.graph import StateGraph, END
from langchain_groq import ChatGroq

import gradio as gr
# Set your Groq API Key
os.environ["GROQ_API_KEY"] = "gSk_akED1vwdMChrWKLC1 MOmWGdyb3FY5uRW16LCg70xaLUhTVQZAa4h"
class RocketState(TypedDict):
    temperature: float
    threshold: float
    decision: str
    llm_output: str

llm = ChatGroq(
    model="llama-3.1-8b-instant",
    temperature=0
)
def safety_check(state: RocketState):
    if state["temperature"] > state["threshold"]:
        state["decision"] = "SHUTDOWN"
    else:
        state["decision"] = "NORMAL"
    return state
def llm_decision(state: RocketState):
    prompt = f"""
    You are an Aerospace Safety AI system.

    Analyze the situation:
    - Engine Temperature: {state['temperature']} °C
    - Safety Threshold: {state['threshold']} °C
    - System Decision: {state['decision']}

    Generate a PROFESSIONAL aerospace-grade response with:
    - Status Header (SAFE / CRITICAL)
    - Clear reasoning
    - Action taken
    - Safety recommendation

    Use clean formatting with emojis and sections.
    """

    response = llm.invoke(prompt)
    state["llm_output"] = response.content
    return state
builder = StateGraph(RocketState)

builder.add_node("safety_check", safety_check)
builder.add_node("llm_decision", llm_decision)

builder.set_entry_point("safety_check")

builder.add_edge("safety_check", "llm_decision")
builder.add_edge("llm_decision", END)

graph = builder.compile()

def run_agent(temp, threshold):
    result = graph.invoke({
        "temperature": temp,
        "threshold": threshold
    })
    return result["llm_output"]
