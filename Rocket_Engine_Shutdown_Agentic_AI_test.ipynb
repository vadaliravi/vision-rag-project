# ==============================
# 2️⃣ Import Libraries
# ==============================
from langgraph.graph import StateGraph, END
from groq import Groq
from rich.console import Console
from rich.panel import Panel
from rich.text import Text
from datetime import datetime
 
# ==============================
# 3️⃣ Setup Groq API
# ==============================
GROQ_API_KEY = "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"
client = Groq(api_key=GROQ_API_KEY)
 
 
def call_llm(prompt):
    response = client.chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.3
    )
    return response.choices[0].message.content
 
# ==============================
# 🧠 MEMORY MODULE
# ==============================
# Simple in-memory store (can be replaced with DB later)
MEMORY = {
    "history": [],
    "shutdown_count": 0
}
 
 
def update_memory(state):
    record = {
        "timestamp": str(datetime.now()),
        "sensor_data": state["sensor_data"],
        "decision": state["decision"],
        "reasons": state["reasons"]
    }
 
    MEMORY["history"].append(record)
 
    if state["decision"] == "SHUTDOWN":
        MEMORY["shutdown_count"] += 1
 
    state["memory"] = MEMORY
    return state
 
# ==============================
# 4️⃣ Engine Shutdown Logic
# ==============================
def engine_check(state):
    data = state["sensor_data"]
   
    shutdown = False
    reasons = []
   
    if data["temperature"] > 98:
        shutdown = True
        reasons.append("High Temperature")
       
    if data["vibration"] > 10:
        shutdown = True
        reasons.append("Excessive Vibration")
       
    if data["pressure"] > 2.5:
        shutdown = True
        reasons.append("High Pressure")
       
    if data["oil_temp"] > 300:
        shutdown = True
        reasons.append("High Oil Temperature")
   
    state["decision"] = "SHUTDOWN" if shutdown else "RUNNING"
    state["reasons"] = reasons
   
    return state
 
# ==============================
# 5️⃣ LLM Decorator with Memory
# ==============================
def llm_decorator(state):
    decision = state["decision"]
    reasons = ", ".join(state["reasons"]) if state["reasons"] else "All parameters normal"
    shutdown_count = state["memory"]["shutdown_count"]
 
    prompt = f"""
    You are an industrial AI safety assistant.
 
    Current Decision: {decision}
    Reasons: {reasons}
 
    Historical Context:
    Total Shutdowns so far: {shutdown_count}
 
    Generate a professional status report with:
    - Emojis
    - Warning tone if shutdown
    - Mention historical pattern
    - Clear engineering summary
    """
 
    state["llm_output"] = call_llm(prompt)
    return state
 
# ==============================
# 6️⃣ Build LangGraph
# ==============================
builder = StateGraph(dict)
 
builder.add_node("engine_check", engine_check)
builder.add_node("update_memory", update_memory)
builder.add_node("llm_decorator", llm_decorator)
 
builder.set_entry_point("engine_check")
 
builder.add_edge("engine_check", "update_memory")
builder.add_edge("update_memory", "llm_decorator")
builder.add_edge("llm_decorator", END)
 
graph = builder.compile()
 
# ==============================
# 7️⃣ Rich UI Output
# ==============================
console = Console()
 
 
def show_output(state):
    decision = state["decision"]
    output = state["llm_output"]
    shutdown_count = state["memory"]["shutdown_count"]
 
    banner = Text("⚙️ ENGINE MONITORING SYSTEM", style="bold black on cyan")
    console.print(Panel(banner, expand=True))
 
    color = "red" if decision == "SHUTDOWN" else "green"
 
    console.print(
        Panel(
            output,
            title=f"STATUS: {decision}",
            subtitle=f"Total Shutdowns: {shutdown_count}",
            border_style=color
        )
    )
 
# ==============================
# 8️⃣ Run Multiple Cycles (Shows Memory)
# ==============================
inputs = [
    {"sensor_data": {"temperature": 90, "vibration": 5, "pressure": 2.0, "oil_temp": 200}},
    {"sensor_data": {"temperature": 105, "vibration": 8, "pressure": 2.0, "oil_temp": 310}},
    {"sensor_data": {"temperature": 85, "vibration": 12, "pressure": 3.0, "oil_temp": 250}},
]
 
for i, inp in enumerate(inputs):
    print(f"\n--- Cycle {i+1} ---")
    result = graph.invoke(inp)
    show_output(result)
 
import json
print(json.dumps(MEMORY, indent=4))    
 
