# ── Core agent invocation for Gradio ───────────────────────
def analyze_engine(engine_id, temperature, threshold, pressure, fuel_flow):
    """Called by Gradio on button click."""
    if not engine_id.strip():
        engine_id = "RS-25-E001"

    try:
        result = run_safety_agent(
            engine_id   = engine_id,
            temperature = float(temperature),
            threshold   = float(threshold),
            pressure    = float(pressure),
            fuel_flow   = float(fuel_flow)
        )

        status   = result["status"]
        shutdown = result["shutdown_triggered"]
        analysis = result["llm_analysis"]

        # Status indicator
        status_icons = {
            "SHUTDOWN": "SHUTDOWN TRIGGERED  [CRITICAL]",
            "WARNING":  "WARNING  [ELEVATED RISK]",
            "NOMINAL":  "NOMINAL  [ALL CLEAR]"
        }
        status_str = status_icons.get(status, status)

        # Temperature deviation
        deviation = ((float(temperature) - float(threshold)) / float(threshold)) * 100
        deviation_str = f"+{deviation:.2f}%" if deviation > 0 else f"{deviation:.2f}%"

        # Summary card
        summary = (
            f"ENGINE ID       : {engine_id}\n"
            f"TEMPERATURE     : {float(temperature):.1f} K\n"
            f"THRESHOLD       : {float(threshold):.1f} K\n"
            f"DEVIATION       : {deviation_str}\n"
            f"PRESSURE        : {float(pressure):.2f} MPa\n"
            f"FUEL FLOW       : {float(fuel_flow):.1f} kg/s\n"
            f"REFLEX DECISION : {status}\n"
            f"SHUTDOWN FLAG   : {'ACTIVE' if shutdown else 'INACTIVE'}\n"
            f"TIMESTAMP       : {result['timestamp']}"
        )

        return status_str, summary, analysis

    except Exception as e:
        error_msg = f"[SYSTEM ERROR] {str(e)}"
        return "ERROR", error_msg, error_msg


