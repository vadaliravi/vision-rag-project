# ============================================================
#  CELL 4: Simple Reflex Agent Logic with LangGraph
#  Rule: IF engine_temperature > threshold THEN trigger shutdown
# ============================================================

# ── 4.1 Agent State Schema ─────────────────────────────────
class EngineState(TypedDict):
    engine_id:         str
    engine_temperature: float
    threshold:         float
    pressure:          float
    fuel_flow:         float
    status:            Literal["NOMINAL", "WARNING", "CRITICAL", "SHUTDOWN"]
    reflex_decision:   str
    llm_analysis:      str
    shutdown_triggered: bool
    timestamp:         str


# ── 4.2 Sensor Input Node ─────────────────────────────────
def sensor_input_node(state: EngineState) -> EngineState:
    """Reads and validates incoming sensor telemetry data."""
    print(f"[SENSOR] Receiving telemetry for Engine: {state['engine_id']}")
    print(f"[SENSOR] Temperature: {state['engine_temperature']} K  |  Threshold: {state['threshold']} K")
    return state


# ── 4.3 Simple Reflex Rule Node ───────────────────────────
def reflex_rule_node(state: EngineState) -> EngineState:
    """
    CORE SIMPLE REFLEX RULE:
    IF engine_temperature > threshold THEN trigger automatic shutdown.
    """
    temp      = state["engine_temperature"]
    threshold = state["threshold"]

    if temp > threshold:
        state["shutdown_triggered"] = True
        state["reflex_decision"]    = "SHUTDOWN"
        state["status"]             = "SHUTDOWN"
        print(f"[REFLEX RULE] FIRED >> Temperature {temp} K exceeds threshold {threshold} K. SHUTDOWN TRIGGERED.")
    elif temp > threshold * 0.90:
        state["shutdown_triggered"] = False
        state["reflex_decision"]    = "WARNING"
        state["status"]             = "WARNING"
        print(f"[REFLEX RULE] WARNING >> Temperature {temp} K approaching threshold ({threshold * 0.90:.1f} K).")
    else:
        state["shutdown_triggered"] = False
        state["reflex_decision"]    = "NOMINAL"
        state["status"]             = "NOMINAL"
        print(f"[REFLEX RULE] NOMINAL >> Engine operating within safe parameters.")

    return state


# ── 4.4 Conditional Router ────────────────────────────────
def route_decision(state: EngineState) -> str:
    """Routes to LLM analysis node based on reflex decision."""
    if state["reflex_decision"] == "SHUTDOWN":
        return "llm_shutdown_analysis"
    elif state["reflex_decision"] == "WARNING":
        return "llm_warning_analysis"
    else:
        return "llm_nominal_analysis"


# ── 4.5 Build LangGraph ───────────────────────────────────
workflow = StateGraph(EngineState)

# Register nodes
workflow.add_node("sensor_input",         sensor_input_node)
workflow.add_node("reflex_rule",          reflex_rule_node)
# LLM analysis is handled by a single dynamic node below

def llm_analysis_node(state: EngineState) -> EngineState:
    """
    LLM Decision Node: Generates decorated safety analysis
    based on the reflex agent's decision.
    """
    # Will be defined in Cell 5
    return state

workflow.add_node("llm_analysis", llm_analysis_node)

# Define edges
workflow.set_entry_point("sensor_input")
workflow.add_edge("sensor_input", "reflex_rule")
workflow.add_edge("reflex_rule",  "llm_analysis")
workflow.add_edge("llm_analysis", END)

# Compile (placeholder — full compilation in Cell 5)
print("[LANGGRAPH] Graph structure defined. Nodes and edges registered.")
print("  Entry --> sensor_input --> reflex_rule --> llm_analysis --> END")

# ============================================================
#  CELL 5: LLM Decision Node — Decorated Analysis Output
# ============================================================

def llm_analysis_node(state: EngineState) -> EngineState:
    """
    LLM Node: Calls Groq llama-3.1-8b-instant to produce a
    rich, decorated technical safety analysis report.
    """
    decision    = state["reflex_decision"]
    temp        = state["engine_temperature"]
    threshold   = state["threshold"]
    pressure    = state["pressure"]
    fuel_flow   = state["fuel_flow"]
    engine_id   = state["engine_id"]
    timestamp   = state["timestamp"]

    # ── Craft contextual system prompt ──────────────────────
    system_prompt = """
You are SENTINEL — an advanced AI Safety Monitor for rocket propulsion systems at Collins Aerospace.
Your role is to analyze engine telemetry data and produce a DECORATED, STRUCTURED safety report.

RESPONSE FORMAT (strictly follow this structure):
============================================================
  SENTINEL SAFETY REPORT — COLLINS AEROSPACE
  Propulsion Safety Intelligence System v3.7
============================================================
  ENGINE:         [engine_id]
  TIMESTAMP:      [timestamp]
  STATUS:         [STATUS WITH CAPS]
  DECISION:       [SHUTDOWN / WARNING / NOMINAL]
------------------------------------------------------------
  TELEMETRY SUMMARY:
  > Temperature:  [value] K  (Threshold: [threshold] K)
  > Pressure:     [value] MPa
  > Fuel Flow:    [value] kg/s
  > Deviation:    [percentage above/below threshold]%
------------------------------------------------------------
  RISK ASSESSMENT:
  [2-3 sentences explaining the risk level clearly]
------------------------------------------------------------
  ACTION TAKEN:
  [Specific action — automatic shutdown / monitor / clear]
------------------------------------------------------------
  TECHNICAL RECOMMENDATION:
  [2-3 technical recommendations for engineers]
------------------------------------------------------------
  SAFETY CLASSIFICATION:  [CRITICAL / ELEVATED / NOMINAL]
  CONFIDENCE LEVEL:       [HIGH / MEDIUM / LOW]
============================================================
    """

    # ── Craft user message ──────────────────────────────────
    user_message = f"""
Analyze the following rocket engine telemetry and generate the safety report:

Engine ID:          {engine_id}
Timestamp:          {timestamp}
Engine Temperature: {temp} K
Safety Threshold:   {threshold} K
Chamber Pressure:   {pressure} MPa
Fuel Flow Rate:     {fuel_flow} kg/s
Reflex Decision:    {decision}
Shutdown Triggered: {state['shutdown_triggered']}

Generate the full SENTINEL SAFETY REPORT as instructed.
    """

    messages = [
        SystemMessage(content=system_prompt),
        HumanMessage(content=user_message)
    ]

    try:
        response = llm.invoke(messages)
        state["llm_analysis"] = response.content
        print("[LLM] SENTINEL analysis generated successfully.")
    except Exception as e:
        state["llm_analysis"] = f"[LLM ERROR] Failed to generate analysis: {str(e)}"
        print(f"[LLM ERROR] {str(e)}")

    return state


# ── Rebuild and compile the full graph ──────────────────────
workflow = StateGraph(EngineState)
workflow.add_node("sensor_input", sensor_input_node)
workflow.add_node("reflex_rule",  reflex_rule_node)
workflow.add_node("llm_analysis", llm_analysis_node)

workflow.set_entry_point("sensor_input")
workflow.add_edge("sensor_input", "reflex_rule")
workflow.add_edge("reflex_rule",  "llm_analysis")
workflow.add_edge("llm_analysis", END)

app = workflow.compile()
print("[LANGGRAPH] Graph compiled successfully. Agent ready.")


# ── Main runner function ─────────────────────────────────────
def run_safety_agent(engine_id: str,
                     temperature: float,
                     threshold: float,
                     pressure: float,
                     fuel_flow: float) -> dict:
    """Runs the LangGraph reflex agent pipeline."""
    from datetime import datetime, timezone

    initial_state: EngineState = {
        "engine_id":            engine_id,
        "engine_temperature":   temperature,
        "threshold":            threshold,
        "pressure":             pressure,
        "fuel_flow":            fuel_flow,
        "status":               "NOMINAL",
        "reflex_decision":      "NOMINAL",
        "llm_analysis":         "",
        "shutdown_triggered":   False,
        "timestamp":            datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC")
    }

    result = app.invoke(initial_state)
    return result

