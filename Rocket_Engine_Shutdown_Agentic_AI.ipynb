                    precision=1,
                )

            gr.HTML('<div class="ca-divider"></div>')
            gr.HTML('<div class="section-label">Quick Scenarios</div>')

            scenario_dd = gr.Dropdown(
                choices=[
                    "Critical Overheat (SHUTDOWN)",
                    "Warning Zone",
                    "Normal Operation",
                    "Extreme Overheat",
                ],
                label="Load Test Scenario",
                value="Critical Overheat (SHUTDOWN)",
            )

            load_btn = gr.Button(
                "LOAD SCENARIO",
                elem_classes=["ca-btn-primary"],
                variant="secondary",
            )

            gr.HTML('<div class="ca-divider"></div>')

            run_btn = gr.Button(
                "EXECUTE SAFETY ANALYSIS",
                elem_classes=["ca-btn-primary"],
                variant="primary",
            )

            gr.HTML('</div>')

        # ── RIGHT COLUMN: Outputs ────────────────────────────
        with gr.Column(scale=6, min_width=400):
            gr.HTML('<div class="ca-card">')

            gr.HTML('<div class="section-label">System Status</div>')

            status_out = gr.Textbox(
                label="REFLEX AGENT DECISION",
                lines=1,
                interactive=False,
                elem_classes=["status-box"],
            )

            gr.HTML('<div class="ca-divider"></div>')
            gr.HTML('<div class="section-label">Telemetry Summary</div>')

            summary_out = gr.Textbox(
                label="Live Telemetry Data",
                lines=9,
                interactive=False,
            )

            gr.HTML('</div>')

    # ── Full SENTINEL Report ─────────────────────────────────
    with gr.Row():
        with gr.Column():
            gr.HTML('<div class="ca-card">')
            gr.HTML('<div class="section-label">SENTINEL AI Safety Report — LLM Analysis (llama-3.1-8b-instant via Groq)</div>')

            analysis_out = gr.Textbox(
                label="SENTINEL SAFETY REPORT",
                lines=28,
                interactive=False,
            )
            gr.HTML('</div>')

    # ── Footer ───────────────────────────────────────────────
    gr.HTML(FOOTER_HTML)

    # ── Event wiring ─────────────────────────────────────────
    load_btn.click(
        fn=load_scenario,
        inputs=[scenario_dd],
        outputs=[engine_id_inp, temp_inp, threshold_inp, pressure_inp, fuel_inp],
    )

    run_btn.click(
        fn=analyze_engine,
        inputs=[engine_id_inp, temp_inp, threshold_inp, pressure_inp, fuel_inp],
        outputs=[status_out, summary_out, analysis_out],
    )

# ── Launch ────────────────────────────────────────────────────
demo.launch(
    debug       = True,
    share       = True,    # Creates a public Gradio link in Colab
    show_error  = True
)
